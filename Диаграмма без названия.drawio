        <mxCell id="QpjOtmhJEpjj2pn00NZO-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=25;" value="Модели, Схемы" vertex="1">
